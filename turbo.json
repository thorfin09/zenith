{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "dist-client/**"]
    },
    "client#build": {
      "outputs": ["dist/**"]
    },
    "desktop#build": {
      "dependsOn": ["client#build"],
      "outputs": ["dist/**", "dist-client/**"]
    },
    "mac#build": {
      "dependsOn": ["client#build"],
      "outputs": ["dist/**", "dist-client/**"]
    },
    "linux#build": {
      "dependsOn": ["client#build"],
      "outputs": ["dist/**", "dist-client/**"]
    },
    "ios#build": {
      "dependsOn": ["client#build"],
      "outputs": ["dist-client/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
