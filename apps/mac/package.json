{
  "name": "mac-app",
  "version": "3.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npm run copy-client && electron-builder",
    "copy-client": "node copy-client.js"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "electronVersion": "31.0.0",
    "appId": "com.zenith.macapp",
    "productName": "Zenith",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "dist-client/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
